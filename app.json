{
  "expo": {
    "name": "DogsOut",
    "slug": "client",
    "scheme": "dogsout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E9E6B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dogsout.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.844535271431-3fiqhj3m9mpn8r2d3mtujae8kt1uecng"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E9E6B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DogsOut needs your location to show nearby dogs."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DogsOut needs access to your photos to set a profile picture."
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#2E9E6B"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4c7cb57c-4d54-4ca3-bc97-346b2758f12f"
      }
    },
    "owner": "moritzdav"
  }
}
